{
  "name": "mimo2codex",
  "version": "0.1.0",
  "description": "Local proxy that lets the latest OpenAI Codex CLI / desktop talk to Xiaomi MiMo (V2.5 Pro) via Responses API by translating to Chat Completions on the fly.",
  "keywords": [
    "codex",
    "openai",
    "mimo",
    "xiaomi",
    "xiaomimimo",
    "responses-api",
    "chat-completions",
    "proxy",
    "adapter",
    "router"
  ],
  "type": "module",
  "bin": {
    "mimo2codex": "dist/cli.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.0",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/mimo2codex"
  }
}
